import frappe


def seed_lebanon_addresses():
	"""Seed Lebanese administrative divisions: Mohafaza -> Caza -> City/Municipality"""
	seed_mohafazat()
	seed_cazas()
	seed_cities()
	frappe.db.commit()


def seed_mohafazat():
	"""Seed 9 Governorates (Mohafazat) of Lebanon with ISO 3166-2 codes"""
	mohafazat = [
		{"mohafaza_name_en": "Akkar", "mohafaza_name_ar": "عكار", "iso_code": "LB-AK", "hasc_code": "LB.AA", "fips_code": "LE10", "capital": "Halba", "area_km2": 776, "population": 432000},
		{"mohafaza_name_en": "Baalbek-Hermel", "mohafaza_name_ar": "بعلبك - الهرمل", "iso_code": "LB-BH", "hasc_code": "LB.BH", "fips_code": "LE11", "capital": "Baalbek", "area_km2": 3009, "population": 472000},
		{"mohafaza_name_en": "Beirut", "mohafaza_name_ar": "بيروت", "iso_code": "LB-BA", "hasc_code": "LB.BA", "fips_code": "LE04", "capital": "Beirut", "area_km2": 18, "population": 419000},
		{"mohafaza_name_en": "Beqaa", "mohafaza_name_ar": "البقاع", "iso_code": "LB-BI", "hasc_code": "LB.BQ", "fips_code": "LE08", "capital": "Zahleh", "area_km2": 1271, "population": 540000},
		{"mohafaza_name_en": "Keserwan-Jbeil", "mohafaza_name_ar": "كسروان - جبيل", "iso_code": "", "hasc_code": "LB.KJ", "fips_code": "", "capital": "Jounieh", "area_km2": 722, "population": 300000},
		{"mohafaza_name_en": "Mount Lebanon", "mohafaza_name_ar": "جبل لبنان", "iso_code": "LB-JL", "hasc_code": "LB.JL", "fips_code": "LE05", "capital": "Baabda", "area_km2": 1238, "population": 1531000},
		{"mohafaza_name_en": "Nabatieh", "mohafaza_name_ar": "النبطية", "iso_code": "LB-NA", "hasc_code": "LB.NA", "fips_code": "LE07", "capital": "Nabatiye", "area_km2": 1058, "population": 391000},
		{"mohafaza_name_en": "North Lebanon", "mohafaza_name_ar": "الشمال", "iso_code": "LB-AS", "hasc_code": "LB.NL", "fips_code": "LE09", "capital": "Tripoli", "area_km2": 1205, "population": 803000},
		{"mohafaza_name_en": "South Lebanon", "mohafaza_name_ar": "الجنوب", "iso_code": "LB-JA", "hasc_code": "LB.JA", "fips_code": "LE06", "capital": "Sidon", "area_km2": 943, "population": 602000},
	]

	for m in mohafazat:
		if not frappe.db.exists("LB Mohafaza", m["mohafaza_name_en"]):
			doc = frappe.new_doc("LB Mohafaza")
			doc.update(m)
			doc.enabled = 1
			doc.insert(ignore_permissions=True)
			frappe.logger().info(f"Created LB Mohafaza: {m['mohafaza_name_en']}")



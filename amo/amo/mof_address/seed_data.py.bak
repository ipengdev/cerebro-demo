		for city_name in city_list:
			doc_name = f"{city_name} - {caza_name}"
			if not frappe.db.exists("LB City", doc_name):
				doc = frappe.new_doc("LB City")
				doc.city_name_en = city_name
				doc.caza = caza_name
				doc.mohafaza = mohafaza_name
				doc.enabled = 1
				doc.insert(ignore_permissions=True)

	frappe.logger().info("Finished seeding LB City records")
